@page Semantic Elements

@header [padding 20, background #f0f0f0]
  @text [bold, size 24] My Site

@nav [spacing 10]
  @link / Home
  @link /about About
  @link /contact Contact

@main [padding 20]
  @article [padding 16, border 1 #ddd, rounded 8]
    @text [bold] Article Title
    @paragraph Some article content here

  @section [padding 16]
    @text [bold] Section Title
    @paragraph Section content

@aside [padding 16, background #f8f8f8]
  @text Related links

@footer [padding 20, background #333, color white]
  @text Copyright 2024
