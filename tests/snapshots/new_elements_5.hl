@page New Elements 5

@column [spacing 20]
  -- Avatar
  @avatar [width 48, height 48, background #e5e7eb]
    @text AB

  -- Carousel
  @carousel [gap 16]
    @el [width 200, padding 20, background #f3f4f6, rounded 8]
      Slide 1
    @el [width 200, padding 20, background #f3f4f6, rounded 8]
      Slide 2

  -- Chip
  @chip [background #e5e7eb] Category

  -- Tag
  @tag [background #dbeafe, color #1e40af] v2.0
