@page New CSS

@el [margin 10, margin-x 20, margin-y 30]
  @text Margins

@image [width 200, height 200, object-fit cover, object-position center] photo.jpg

@el [filter blur(5px), pointer-events none, user-select none]
  @text Filtered

@row [justify-content space-between, align-items center]
  @text Left
  @text Right

@el [order 2]
  @text Second

@el [background url(bg.jpg), background-size cover, background-position center, background-repeat no-repeat]
  @text Background

@text [text-shadow 1px 1px 2px black, text-overflow ellipsis] Shadowed

@el [word-break break-all, overflow-wrap break-word]
  @text Longtext
