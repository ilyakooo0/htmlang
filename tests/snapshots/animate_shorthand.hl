@page Animate
@keyframes fade-in
  from [opacity 0]
  to [opacity 1]
@keyframes slide-up
  from [transform translateY(20px), opacity 0]
  to [transform translateY(0), opacity 1]
@column [spacing 20, padding 20]
  @el [animate fade-in 0.3s ease, padding 20]
    Faded in
  @el [animate slide-up 0.5s ease-out, padding 20, background #e5e7eb]
    Slid up
