@page Stress Test Large Document

@let --primary #3b82f6
@let --secondary #10b981
@let --accent #f59e0b
@let --danger #ef4444
@let --dark #1e293b
@let --light #f8fafc
@let --gray #64748b
@let --border #e2e8f0
@let --radius 8
@let --gap 16
@let --gap-sm 8
@let --gap-lg 24

@keyframes fade-in
  from{opacity:0}to{opacity:1}

@keyframes slide-down
  0%{transform:translateY(-10px);opacity:0}100%{transform:translateY(0);opacity:1}

@fn icon-button $label $color=var(--primary)
  @button [padding 8 16, background $color, hover:background $--dark, color white, rounded 6, border none, cursor pointer, transition all 0.2s, font-size 14]
    $label

@fn badge $label $variant=blue
  @el [display inline-block, padding 2 8, background $variant, color white, rounded 12, font-size 12]
    @text $label

@fn card $title
  @el [background white, dark:background #1e293b, rounded $--radius, padding $--gap, border 1 $--border, dark:border 1 #334155, hover:shadow 0 4 12 rgba(0,0,0,0.1), transition all 0.2s, animation fade-in 0.3s ease]
    @text [bold, size 18, color $--dark, dark:color white] $title
    @el [margin-top 8]
      @children

@fn stat-card $label $value $change
  @el [background white, dark:background #1e293b, rounded $--radius, padding $--gap, border 1 $--border, dark:border 1 #334155]
    @text [size 14, color $--gray] $label
    @text [bold, size 28, color $--dark, dark:color white, margin-top 4] $value
    @text [size 12, color $--secondary, margin-top 2] $change

@fn nav-link $url $label $active=false
  @if $active == true
    @link [color $--primary, bold, padding 8 12, background #eff6ff, dark:background #1e3a5f, rounded 6] $url $label
  @else
    @link [color $--gray, hover:color $--primary, padding 8 12, hover:background #f1f5f9, dark:hover:background #334155, rounded 6, transition all 0.15s] $url $label

@fn sidebar-section $title
  @el [margin-bottom $--gap-lg]
    @text [bold, size 12, color $--gray, text-transform uppercase, letter-spacing 1, margin-bottom $--gap-sm] $title
    @children

@fn avatar $initials $size=32
  @el [width $size, height $size, rounded 50%, background $--primary, color white, display flex, align-items center, justify-content center, font-size 14, bold]
    @text $initials

@fn table-row $col1 $col2 $col3 $col4
  @row [spacing 0, padding 12 16, border-bottom 1 $--border, dark:border-bottom 1 #334155, hover:background #f8fafc, dark:hover:background #1e293b]
    @el [width 200]
      @text [size 14] $col1
    @el [width 150]
      @text [size 14, color $--gray] $col2
    @el [width 120]
      @text [size 14] $col3
    @el [width fill]
      @text [size 14, color $--gray] $col4

@fn breadcrumb-item $url $label $is-last=false
  @if $is-last == true
    @text [color $--dark, dark:color white, size 14] $label
  @else
    @row [spacing 8]
      @link [color $--gray, hover:color $--primary, size 14] $url $label
      @text [color $--border, size 14] /

@fn alert $message $type=info
  @if $type == info
    @el [background #eff6ff, border 1 #bfdbfe, rounded $--radius, padding 12 16]
      @text [color #1e40af, size 14] $message
  @else if $type == success
    @el [background #f0fdf4, border 1 #bbf7d0, rounded $--radius, padding 12 16]
      @text [color #166534, size 14] $message
  @else if $type == warning
    @el [background #fffbeb, border 1 #fde68a, rounded $--radius, padding 12 16]
      @text [color #92400e, size 14] $message
  @else
    @el [background #fef2f2, border 1 #fecaca, rounded $--radius, padding 12 16]
      @text [color #991b1b, size 14] $message

@fn progress-bar $percent $color=var(--primary)
  @el [width fill, height 8, background #e2e8f0, dark:background #334155, rounded 4, overflow hidden]
    @el [width $percent%, height fill, background $color, rounded 4]

@fn tag $label
  @el [display inline-block, padding 4 10, background #f1f5f9, dark:background #334155, color $--gray, dark:color #94a3b8, rounded 4, font-size 12, margin 2]
    @text $label

@fn notification-dot
  @el [width 8, height 8, rounded 50%, background $--danger]

@fn divider
  @el [width fill, height 1, background $--border, dark:background #334155, margin 8 0]

@fn toggle $checked=false
  @if $checked == true
    @el [width 40, height 22, rounded 11, background $--primary, padding 2, cursor pointer, transition all 0.2s]
      @el [width 18, height 18, rounded 50%, background white, margin-left 18, transition all 0.2s]
  @else
    @el [width 40, height 22, rounded 11, background #cbd5e1, dark:background #475569, padding 2, cursor pointer, transition all 0.2s]
      @el [width 18, height 18, rounded 50%, background white, transition all 0.2s]

@let nav-items home,products,team,blog,docs,pricing
@let categories all,design,development,marketing,analytics
@let team-members Alice,Bob,Carol,Dave,Eve,Frank,Grace,Hank
@let statuses active,pending,completed,archived
@let projects Alpha,Beta,Gamma,Delta,Epsilon

@row [spacing 0, min-height 100vh]

  @column [width 260, background white, dark:background #0f172a, border-right 1 $--border, dark:border-right 1 #1e293b, padding $--gap, spacing $--gap-sm]

    @row [spacing 12, padding 8, align-items center]
      @avatar [initials HL, size 36]
      @column [spacing 2]
        @text [bold, size 16, color $--dark, dark:color white] htmlang
        @text [size 12, color $--gray] Dashboard v2.0

    @divider

    @sidebar-section [title Navigation]
      @column [spacing 2]
        @nav-link [url /dashboard, label Dashboard, active true]
        @nav-link [url /analytics, label Analytics]
        @nav-link [url /projects, label Projects]
        @nav-link [url /team, label Team]
        @nav-link [url /messages, label Messages]
        @nav-link [url /calendar, label Calendar]
        @nav-link [url /documents, label Documents]
        @nav-link [url /settings, label Settings]

    @sidebar-section [title Favorites]
      @column [spacing 2]
        @nav-link [url /project/alpha, label Project Alpha]
        @nav-link [url /project/beta, label Project Beta]
        @nav-link [url /reports/q4, label Q4 Reports]

    @sidebar-section [title Shortcuts]
      @column [spacing 4]
        @row [spacing 8, align-items center]
          @el [width 6, height 6, rounded 50%, background $--secondary]
          @text [size 13, color $--gray] Online (12)
        @row [spacing 8, align-items center]
          @el [width 6, height 6, rounded 50%, background $--accent]
          @text [size 13, color $--gray] Away (3)
        @row [spacing 8, align-items center]
          @el [width 6, height 6, rounded 50%, background #cbd5e1]
          @text [size 13, color $--gray] Offline (5)

    @el [margin-top auto, padding 12, background #f1f5f9, dark:background #1e293b, rounded $--radius]
      @row [spacing 8, align-items center]
        @avatar [initials JD, size 28]
        @column [spacing 0]
          @text [size 13, bold, color $--dark, dark:color white] Jane Doe
          @text [size 11, color $--gray] jane@example.com

  @column [width fill, background $--light, dark:background #0f172a]

    @header [padding 12 24, background white, dark:background #0f172a, border-bottom 1 $--border, dark:border-bottom 1 #1e293b]
      @row [spacing 16, align-items center]
        @column [spacing 2]
          @row [spacing 8]
            @breadcrumb-item [url /, label Home]
            @breadcrumb-item [url /dashboard, label Dashboard, is-last true]
          @text [bold, size 22, color $--dark, dark:color white] Dashboard Overview

        @el [width fill]

        @row [spacing 12, align-items center]
          @input [type search, placeholder Search..., padding 8 12, rounded 6, border 1 $--border, dark:border 1 #334155, dark:background #1e293b, dark:color white, width 240, focus:border 1 $--primary, transition all 0.2s]
          @el [position relative]
            @icon-button [label Alerts]
            @el [position absolute, top -2, right -2]
              @notification-dot
          @icon-button [label Settings, color $--gray]

    @el [padding $--gap-lg, overflow-y auto]

      @alert [message Welcome back! You have 3 new notifications and 2 pending tasks., type info]

      @row [spacing $--gap, margin-top $--gap-lg, sm:flex-direction column, lg:flex-direction row]
        @stat-card [label Total Revenue, value $48,295, change +12.5% from last month]
        @stat-card [label Active Users, value 2,847, change +8.2% from last week]
        @stat-card [label Conversion Rate, value 3.24%, change +0.4% from yesterday]
        @stat-card [label Open Tickets, value 142, change -5.1% from last month]

      @row [spacing $--gap, margin-top $--gap-lg]

        @card [title Revenue Overview]
          @el [height 200, background #f8fafc, dark:background #0f172a, rounded 6, margin-top 12, display flex, align-items flex-end, padding 16, gap 8]
            @each $height in 40,65,45,80,55,70,90,60,75,85,50,95
              @el [width fill, height $height%, background $--primary, hover:background #2563eb, rounded 4 4 0 0, transition all 0.2s, min-width 20]

        @card [title Activity Feed]
          @column [spacing 12, margin-top 12]
            @each $member in $team-members
              @row [spacing 12, align-items center, padding 8, hover:background #f8fafc, dark:hover:background #1e293b, rounded 6]
                @avatar [initials $member, size 32]
                @column [spacing 2, width fill]
                  @text [size 14, bold, color $--dark, dark:color white] $member
                  @text [size 12, color $--gray] Updated project files
                @text [size 11, color $--gray] 2h ago

      @row [spacing $--gap, margin-top $--gap-lg, sm:flex-direction column, lg:flex-direction row]

        @column [width fill, spacing $--gap]

          @card [title Project Status]
            @column [spacing 0, margin-top 12]
              @row [spacing 0, padding 8 16, background #f8fafc, dark:background #0f172a, border-bottom 1 $--border]
                @el [width 200]
                  @text [bold, size 12, color $--gray, text-transform uppercase] Project
                @el [width 150]
                  @text [bold, size 12, color $--gray, text-transform uppercase] Status
                @el [width 120]
                  @text [bold, size 12, color $--gray, text-transform uppercase] Progress
                @el [width fill]
                  @text [bold, size 12, color $--gray, text-transform uppercase] Due Date

              @table-row [col1 Project Alpha, col2 In Progress, col3 75%, col4 Dec 15 2025]
              @table-row [col1 Project Beta, col2 Review, col3 90%, col4 Nov 30 2025]
              @table-row [col1 Project Gamma, col2 Planning, col3 20%, col4 Jan 20 2026]
              @table-row [col1 Project Delta, col2 Completed, col3 100%, col4 Oct 10 2025]
              @table-row [col1 Project Epsilon, col2 On Hold, col3 45%, col4 Feb 28 2026]

          @card [title Progress Breakdown]
            @column [spacing 12, margin-top 12]
              @each $project in $projects
                @column [spacing 4]
                  @row [spacing 0]
                    @text [size 13, color $--dark, dark:color white, width fill] $project
                    @text [size 13, color $--gray] 67%
                  @progress-bar [percent 67, color var(--primary)]

          @card [title Recent Activity Log]
            @column [spacing 8, margin-top 12]
              @let log-entries Deployed v2.3.1 to production,Merged feature/auth-redesign,Closed issue #482: Login timeout,Updated CI/CD pipeline config,Added unit tests for payment module,Reviewed PR #156: API refactor,Fixed memory leak in worker pool,Released hotfix 2.3.2
              @each $entry, $i in $log-entries
                @row [spacing 12, padding 8 12, align-items center]
                  @el [width 24, height 24, rounded 50%, background #eff6ff, dark:background #1e3a5f, display flex, align-items center, justify-content center]
                    @text [size 10, color $--primary, bold] $i
                  @text [size 14, color $--dark, dark:color white, width fill] $entry
                  @text [size 11, color $--gray] just now

        @column [width 340, sm:width fill, spacing $--gap]

          @card [title Quick Actions]
            @column [spacing 8, margin-top 12]
              @icon-button [label New Project, color var(--primary)]
              @icon-button [label Create Report, color var(--secondary)]
              @icon-button [label Invite Member, color var(--accent)]
              @icon-button [label View Backlog, color var(--gray)]

          @card [title Team Members]
            @column [spacing 8, margin-top 12]
              @each $member in $team-members
                @row [spacing 10, align-items center, padding 6 8, hover:background #f1f5f9, dark:hover:background #1e293b, rounded 6, transition all 0.15s]
                  @avatar [initials $member, size 28]
                  @column [spacing 0, width fill]
                    @text [size 13, bold, color $--dark, dark:color white] $member
                    @text [size 11, color $--gray] Developer
                  @el [width 8, height 8, rounded 50%, background $--secondary]

          @card [title Tags]
            @row [spacing 0, wrap, margin-top 8]
              @tag [label frontend]
              @tag [label backend]
              @tag [label devops]
              @tag [label design]
              @tag [label mobile]
              @tag [label security]
              @tag [label performance]
              @tag [label testing]
              @tag [label docs]
              @tag [label infra]
              @tag [label ux]
              @tag [label api]

          @card [title Notifications]
            @column [spacing 0, margin-top 12]
              @let notifications New deployment completed,PR review requested,Build failed on staging,Meeting in 30 minutes,Subscription renewal due
              @each $note in $notifications
                @row [spacing 10, padding 10 12, border-bottom 1 $--border, dark:border-bottom 1 #334155, align-items center]
                  @notification-dot
                  @text [size 13, color $--dark, dark:color white, width fill] $note
                  @text [size 11, color $--gray] now

          @card [title Settings]
            @column [spacing 12, margin-top 12]
              @row [spacing 0, align-items center]
                @text [size 14, color $--dark, dark:color white, width fill] Dark Mode
                @toggle [checked true]
              @row [spacing 0, align-items center]
                @text [size 14, color $--dark, dark:color white, width fill] Notifications
                @toggle [checked true]
              @row [spacing 0, align-items center]
                @text [size 14, color $--dark, dark:color white, width fill] Auto-save
                @toggle [checked false]
              @row [spacing 0, align-items center]
                @text [size 14, color $--dark, dark:color white, width fill] Compact View
                @toggle [checked false]

      @el [margin-top $--gap-lg]
        @card [title Data Table]
          @column [spacing 0, margin-top 12]
            @row [spacing 16, margin-bottom 12, align-items center]
              @input [type search, placeholder Filter results..., padding 8 12, rounded 6, border 1 $--border, width 240]
              @el [width fill]
              @row [spacing 8]
                @each $cat in $categories
                  @button [padding 6 12, rounded 4, border 1 $--border, background white, dark:background #1e293b, hover:background #f1f5f9, color $--gray, hover:color $--dark, font-size 13, cursor pointer, transition all 0.15s] $cat

            @row [spacing 0, padding 8 16, background #f8fafc, dark:background #0f172a, border-bottom 2 $--border, rounded 6 6 0 0]
              @el [width 60]
                @text [bold, size 12, color $--gray, text-transform uppercase] ID
              @el [width 200]
                @text [bold, size 12, color $--gray, text-transform uppercase] Name
              @el [width 150]
                @text [bold, size 12, color $--gray, text-transform uppercase] Category
              @el [width 120]
                @text [bold, size 12, color $--gray, text-transform uppercase] Status
              @el [width fill]
                @text [bold, size 12, color $--gray, text-transform uppercase] Updated

            @each $status in $statuses
              @each $project in $projects
                @row [spacing 0, padding 10 16, border-bottom 1 $--border, dark:border-bottom 1 #334155, hover:background #f8fafc, dark:hover:background #1e293b, cursor pointer, transition all 0.1s]
                  @el [width 60]
                    @text [size 13, color $--gray] #42
                  @el [width 200]
                    @row [spacing 8, align-items center]
                      @avatar [initials $project, size 24]
                      @text [size 14, color $--dark, dark:color white] $project
                  @el [width 150]
                    @text [size 13, color $--gray] $status
                  @el [width 120]
                    @badge [label $status, variant var(--secondary)]
                  @el [width fill]
                    @text [size 13, color $--gray] 2 hours ago

            @row [spacing 16, padding 12 16, align-items center, border-top 1 $--border]
              @text [size 13, color $--gray] Showing 1-20 of 142 results
              @el [width fill]
              @row [spacing 4]
                @button [padding 6 10, rounded 4, border 1 $--border, background white, dark:background #1e293b, color $--gray, font-size 13, cursor pointer] Prev
                @button [padding 6 10, rounded 4, border 1 $--primary, background $--primary, color white, font-size 13, cursor pointer] 1
                @button [padding 6 10, rounded 4, border 1 $--border, background white, dark:background #1e293b, color $--gray, font-size 13, cursor pointer] 2
                @button [padding 6 10, rounded 4, border 1 $--border, background white, dark:background #1e293b, color $--gray, font-size 13, cursor pointer] 3
                @button [padding 6 10, rounded 4, border 1 $--border, background white, dark:background #1e293b, color $--gray, font-size 13, cursor pointer] Next

    @footer [padding $--gap-lg 24, background white, dark:background #0f172a, border-top 1 $--border, dark:border-top 1 #1e293b]
      @row [spacing $--gap-lg, sm:flex-direction column, lg:flex-direction row]
        @column [spacing 8, width fill]
          @text [bold, size 14, color $--dark, dark:color white] htmlang Dashboard
          @text [size 12, color $--gray] Built with htmlang - a declarative HTML language
          @text [size 11, color $--gray] Copyright 2025 htmlang contributors

        @column [spacing 4]
          @text [bold, size 12, color $--gray, text-transform uppercase, margin-bottom 4] Product
          @link [color $--gray, hover:color $--primary, size 13] /features Features
          @link [color $--gray, hover:color $--primary, size 13] /pricing Pricing
          @link [color $--gray, hover:color $--primary, size 13] /changelog Changelog
          @link [color $--gray, hover:color $--primary, size 13] /roadmap Roadmap

        @column [spacing 4]
          @text [bold, size 12, color $--gray, text-transform uppercase, margin-bottom 4] Resources
          @link [color $--gray, hover:color $--primary, size 13] /docs Documentation
          @link [color $--gray, hover:color $--primary, size 13] /api API Reference
          @link [color $--gray, hover:color $--primary, size 13] /guides Guides
          @link [color $--gray, hover:color $--primary, size 13] /examples Examples

        @column [spacing 4]
          @text [bold, size 12, color $--gray, text-transform uppercase, margin-bottom 4] Company
          @link [color $--gray, hover:color $--primary, size 13] /about About
          @link [color $--gray, hover:color $--primary, size 13] /blog Blog
          @link [color $--gray, hover:color $--primary, size 13] /careers Careers
          @link [color $--gray, hover:color $--primary, size 13] /contact Contact

        @column [spacing 4]
          @text [bold, size 12, color $--gray, text-transform uppercase, margin-bottom 4] Legal
          @link [color $--gray, hover:color $--primary, size 13] /privacy Privacy Policy
          @link [color $--gray, hover:color $--primary, size 13] /terms Terms of Service
          @link [color $--gray, hover:color $--primary, size 13] /cookies Cookie Policy
