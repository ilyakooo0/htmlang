@page Animations

@keyframes fade-in
  from{opacity:0}to{opacity:1}

@keyframes slide-up
  0%{transform:translateY(20px);opacity:0}100%{transform:translateY(0);opacity:1}

@column [spacing 20]
  @el [animation fade-in 0.3s ease]
    @text Fading in
  @el [animation slide-up 0.5s ease-out]
    @text Sliding up
