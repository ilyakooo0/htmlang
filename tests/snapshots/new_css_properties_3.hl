@page New CSS Properties 3

@column [spacing 20]
  @text [font-weight 600] Semi-bold text
  @text [font-style oblique] Oblique text
  @text [text-wrap balance, size 32] A heading that wraps nicely
  @el [will-change transform, transition transform 0.3s ease]
    Optimized for animation
  @el [touch-action none]
    No touch scrolling
  @text [vertical-align middle] Middle aligned
  @el [contain content]
    Contained element
  @el [scroll-margin-top 80]
    Offset for fixed header
  @el [content-visibility auto]
    Lazy rendered content
  @el [scroll-padding 20]
    Scroll padding container
