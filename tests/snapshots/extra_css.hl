@column [spacing 20]
  @el [display none]
    Hidden
  @el [visibility hidden]
    Also hidden
  @el [transform rotate(45deg), backdrop-filter blur(10px)]
    Styled
  @el [letter-spacing 2, text-transform uppercase, white-space nowrap]
    Typography
  @el [border-bottom 1 #ccc, border-top 2 red]
    Borders
  @el [grid, grid-cols 3, gap 10]
    @el [col-span 2]
      Wide
    @el
      Narrow
